# Discord Developer Portal で再生成したBotトークン
DISCORD_TOKEN=

# Discord Developer Portal の Application ID
CLIENT_ID=

# 任意。指定すると、このサーバーだけへコマンドを即時登録（開発・単一サーバー向け）
GUILD_ID=

# 永続データの保存先。Dockerでは /app/data/state.json を使用
DATA_FILE=./data/state.json

# 募集を常に複製投稿するチャンネル
ANNOUNCEMENT_CHANNEL_ID=1256456334287568979

# DM通知の対象となる既存ロール（別サーバーへ移す場合だけ変更）
ROLE_DRINKING=1516889561030983690
ROLE_VALORANT=1256457963971936286
ROLE_MINECRAFT=1503770016498319390
